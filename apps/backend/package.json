{
  "name": "@cuchen/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm --prefix ../../packages/shared run build",
    "dev": "node --import ./register-ts-node.mjs src/main.ts",
    "pretest": "npm --prefix ../../packages/shared run build",
    "prebuild": "npm --prefix ../../packages/shared run build",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "presync:minio-to-mongo": "npm --prefix ../../packages/shared run build",
    "sync:minio-to-mongo": "node --import ./register-ts-node.mjs src/maintenance/sync-minio-to-mongo.ts",
    "presync:reconcile-minio-mongo": "npm --prefix ../../packages/shared run build",
    "sync:reconcile-minio-mongo": "node --import ./register-ts-node.mjs src/maintenance/reconcile-minio-mongo.ts",
    "presync:prune-metadata-columns": "npm --prefix ../../packages/shared run build",
    "sync:prune-metadata-columns": "node --import ./register-ts-node.mjs src/maintenance/prune-metadata-columns.ts",
    "presync:migrate-metadata-schema": "npm --prefix ../../packages/shared run build",
    "sync:migrate-metadata-schema": "node --import ./register-ts-node.mjs src/maintenance/migrate-metadata-schema.ts",
    "presync:backfill-thumbnails": "npm --prefix ../../packages/shared run build",
    "sync:backfill-thumbnails": "node --import ./register-ts-node.mjs src/maintenance/backfill-thumbnails.ts",
    "preseed:bulk-images": "npm --prefix ../../packages/shared run build",
    "seed:bulk-images": "node --import ./register-ts-node.mjs src/maintenance/seed-bulk-images.ts",
    "test": "node --import ./register-ts-node.mjs --test $(find tests -name '*.test.ts' -print)"
  },
  "dependencies": {
    "@cuchen/shared": "file:../../packages/shared",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/platform-express": "^10.4.15",
    "chokidar": "^4.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "minio": "^8.0.6",
    "mongoose": "^8.16.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.30",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
